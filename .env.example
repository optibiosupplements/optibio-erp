# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Neon Postgres pooled connection string.
# Get it from https://console.neon.tech → your project → Dashboard → Connection Details (pick "Pooled connection")
DATABASE_URL=

# Anthropic API key for Eva (intake/CRM agent) and Danny (bench formulator).
# Get it from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Default model used by Eva + Danny.
ANTHROPIC_MODEL=claude-opus-4-7
